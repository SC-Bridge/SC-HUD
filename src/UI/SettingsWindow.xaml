<Window x:Class="schud.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SC HUD — Settings"
        Width="440" Height="480"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#0d1b2a"
        Foreground="#e2e8f0">

    <Window.Resources>

        <Style x:Key="SectionBorder" TargetType="Border">
            <Setter Property="Background" Value="#132238"/>
            <Setter Property="BorderBrush" Value="#2a4a6b"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#5b9bd5"/>
        </Style>

        <Style x:Key="RowLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#cbd5e1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="ValueLabel" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>

        <Style x:Key="RowDivider" TargetType="Border">
            <Setter Property="BorderBrush" Value="#1e3a5f"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#0d1b2a"/>
            <Setter Property="Foreground" Value="#cbd5e1"/>
            <Setter Property="BorderBrush" Value="#2a4a6b"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#cbd5e1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="0,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SaveButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#22d3ee"/>
            <Setter Property="Foreground" Value="#09131f"/>
            <Setter Property="BorderBrush" Value="#22d3ee"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#132238"/>
            <Setter Property="Foreground" Value="#94a3b8"/>
            <Setter Property="BorderBrush" Value="#2a4a6b"/>
        </Style>

    </Window.Resources>

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">

            <!-- CONTROLS section -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <Border Style="{StaticResource RowDivider}" Padding="14,9">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="CONTROLS"/>
                    </Border>
                    <Border Padding="14,10,14,12">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="Toggle Hotkey"/>
                                <TextBox Grid.Column="1" x:Name="HotkeyBox"
                                         Width="148"
                                         IsReadOnly="True"
                                         ContextMenu="{x:Null}"
                                         PreviewKeyDown="OnHotkeyBoxKeyDown"
                                         PreviewKeyUp="OnHotkeyBoxKeyUp"/>
                            </Grid>
                            <TextBlock Style="{StaticResource HintText}"
                                       Text="Click the field, then press a key combination"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- OVERLAY section -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <Border Style="{StaticResource RowDivider}" Padding="14,9">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="OVERLAY"/>
                    </Border>

                    <!-- Opacity -->
                    <Border Style="{StaticResource RowDivider}" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="Opacity"/>
                            <Slider Grid.Column="1" x:Name="OpacitySlider"
                                    Minimum="10" Maximum="100" Width="160"
                                    VerticalAlignment="Center"
                                    ValueChanged="OnOpacityChanged"/>
                            <TextBlock Grid.Column="2" x:Name="OpacityLabel" Style="{StaticResource ValueLabel}"/>
                        </Grid>
                    </Border>

                    <!-- Background Opacity -->
                    <Border Style="{StaticResource RowDivider}" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="Background Opacity"/>
                            <Slider Grid.Column="1" x:Name="BgOpacitySlider"
                                    Minimum="0" Maximum="100" Width="160"
                                    VerticalAlignment="Center"
                                    ValueChanged="OnBgOpacityChanged"/>
                            <TextBlock Grid.Column="2" x:Name="BgOpacityLabel" Style="{StaticResource ValueLabel}"/>
                        </Grid>
                    </Border>

                    <!-- Width -->
                    <Border Style="{StaticResource RowDivider}" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="Content Width"/>
                            <Slider Grid.Column="1" x:Name="WidthSlider"
                                    Minimum="10" Maximum="100" Width="160"
                                    VerticalAlignment="Center"
                                    ValueChanged="OnWidthChanged"/>
                            <TextBlock Grid.Column="2" x:Name="WidthLabel" Style="{StaticResource ValueLabel}"/>
                        </Grid>
                    </Border>

                    <!-- Height -->
                    <Border Style="{StaticResource RowDivider}" Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="Content Height"/>
                            <Slider Grid.Column="1" x:Name="HeightSlider"
                                    Minimum="10" Maximum="100" Width="160"
                                    VerticalAlignment="Center"
                                    ValueChanged="OnHeightChanged"/>
                            <TextBlock Grid.Column="2" x:Name="HeightLabel" Style="{StaticResource ValueLabel}"/>
                        </Grid>
                    </Border>

                    <!-- Zoom -->
                    <Border Padding="14,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource RowLabel}" Text="Zoom"/>
                            <Slider Grid.Column="1" x:Name="ZoomSlider"
                                    Minimum="50" Maximum="150" Width="160"
                                    VerticalAlignment="Center"
                                    ValueChanged="OnZoomChanged"/>
                            <TextBlock Grid.Column="2" x:Name="ZoomLabel" Style="{StaticResource ValueLabel}"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <!-- SYSTEM section -->
            <Border Style="{StaticResource SectionBorder}">
                <StackPanel>
                    <Border Style="{StaticResource RowDivider}" Padding="14,9">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="SYSTEM"/>
                    </Border>
                    <Border Padding="14,10">
                        <CheckBox x:Name="AutoStartBox" Content="Start SC HUD with Windows"/>
                    </Border>
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- Buttons + env indicator -->
        <Grid Grid.Row="1" Margin="0,4,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse x:Name="EnvDot" Width="6" Height="6" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock x:Name="EnvLabel" FontFamily="Segoe UI" FontSize="11" Foreground="#94a3b8" VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Style="{StaticResource SaveButton}"   Content="Save"   Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnSave"/>
                <Button Style="{StaticResource CancelButton}" Content="Cancel" Width="80"                   IsCancel="True"  Click="OnCancel"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
