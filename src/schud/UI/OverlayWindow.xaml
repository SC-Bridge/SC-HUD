<Window x:Class="schud.UI.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        WindowStyle="None"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        WindowStartupLocation="Manual"
        Visibility="Collapsed"
        Title="SC HUD">
    <Window.Background>
        <!-- Near-zero opacity prevents WPF from treating the window as
             fully transparent, which would cause clicks to fall through
             the WebView2 content. Must NOT be zero. -->
        <SolidColorBrush Color="#010000" Opacity="0.05"/>
    </Window.Background>

    <Grid>
        <wv2:WebView2 x:Name="WebView" />
    </Grid>
</Window>
