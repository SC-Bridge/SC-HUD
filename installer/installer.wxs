<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package
    Name="SC Bridge HUD"
    Version="$(var.ProductVersion)"
    Manufacturer="SC-Bridge"
    UpgradeCode="14718258-65BF-4312-AEFA-812D695AF95F"
    Language="1033"
    Scope="perMachine">

    <Icon Id="AppIcon.ico" SourceFile="icon.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon.ico" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of SC Bridge HUD is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER">
      <ui:WixUILicenseRtf Value="license.rtf" />
    </ui:WixUI>

    <Feature Id="Main" Title="SC Bridge HUD" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="SC Bridge HUD" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="SC Bridge HUD" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <Component Id="StartMenuShortcut" Directory="AppMenuFolder">
      <Shortcut
        Id="ApplicationShortcut"
        Name="SC Bridge HUD"
        Description="Star Citizen browser overlay"
        Target="[INSTALLFOLDER]schud.exe"
        WorkingDirectory="INSTALLFOLDER"
        Icon="AppIcon.ico" />
      <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
      <RegistryValue
        Root="HKCU"
        Key="Software\SC-Bridge\SC HUD"
        Name="installed"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>
  </Fragment>

</Wix>
