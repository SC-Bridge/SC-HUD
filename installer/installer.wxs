<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
    Name="SC HUD"
    Version="$(var.ProductVersion)"
    Manufacturer="SC-Bridge"
    UpgradeCode="14718258-65BF-4312-AEFA-812D695AF95F"
    Language="1033"
    Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of SC HUD is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="SC HUD" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="SC HUD" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="SC HUD" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)\**" />
    </ComponentGroup>

    <Component Id="StartMenuShortcut" Directory="AppMenuFolder">
      <Shortcut
        Id="ApplicationShortcut"
        Name="SC HUD"
        Description="Star Citizen browser overlay"
        Target="[INSTALLFOLDER]schud.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
      <RegistryValue
        Root="HKCU"
        Key="Software\SC-Bridge\SC HUD"
        Name="installed"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>
  </Fragment>

</Wix>
